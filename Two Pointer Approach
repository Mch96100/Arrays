#include<iostream>
#include<vector>
using namespace std;    

//two pointer approach to reverse an array
class Solution{
    public:
    vector<int> reverseArray(vector<int> &arr) {
        int n = arr.size();
        int i = 0, j = n-1;
        while(i<j){
            swap(arr[i],arr[j]);
            i++;
            j--;
        }
        return arr;
}
};

int main()
{
    vector<int> arr = {1,2,3,4,5};
    Solution obj;
    vector<int> reversed = obj.reverseArray(arr);

    for (int i=0; i <reversed.size() ; i++){
        cout<<reversed[i]<<" ";
    }
}






