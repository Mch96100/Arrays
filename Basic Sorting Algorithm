                                       //********Bubble Sort Algorithms ****//

//Bubble Sort : It is the simplest sorting algorithm that works by repeatedly swapping the adjacent elements if they are in wrong order.


#include<iostream>
using namespace std;
int main(){
    int arr[5] = {5,4,3,2,1};
    int n = 5;
    for (int i=0; i<n; i++){
        for(int j= 0 ; j<=n-2; j++){
            if(arr[j]>arr[j+1]){
                swap(arr[j],arr[j+1]);
            
        }
    }

}
for(int i=0;i<n;i++){
    cout<<arr[i]<<" ";
}
}



                           /************* Insertion Sort ************/

//Insertion Sort : It is a simple sorting algorithm that builds the final sorted array one item at a time.
//  It is much less efficient on large lists than more advanced algorithms such as quicksort, heapsort, or merge sort.


#include<iostream>
using namespace std;

int main(){
    int arr[7] = {5,4,3,2,1,5,6};
    int n = 7;
    for(int i=1;i<=n;i++){
        for(int j=i;j>0;j--){
            if(arr[j]<arr[j-1]){
                swap(arr[j],arr[j-1]);
            }

        }
    }
    for(int i=0;i<n;i++){
        cout<<arr[i]<<" ";
    }
}


                                       /*********** Selection Sort ***********/
#include<iostream>
using namespace std;

//Selection Sort : It is an in-place comparison sorting algorithm. 
//It has an O(n^2) time complexity, which makes it inefficient on large lists,
// and generally performs worse than the similar insertion sort.

int main(){
    int a[5] = {5,4,3,2,1};
    int n=5;

    for(int i=0;i<n;i++){
    int min_ele_index = i;
        for (int j=i+1; j<=n-1;j++){
            if(a[j]<a[min_ele_index]){
                min_ele_index = j;
            }
        }
        swap(a[i],a[min_ele_index]);
    }
    for(int i=0;i<n;i++){
        cout<<a[i]<<" ";
    }

}




